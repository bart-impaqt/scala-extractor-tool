SCALA_CM_BASE_URL=http://cm4.ddjmusic.com:8080/cm

# Option A: direct token
SCALA_CM_API_TOKEN=

# Option B: login credentials
SCALA_CM_USERNAME=
SCALA_CM_PASSWORD=

# Optional (only when login requires network selection)
SCALA_CM_NETWORK_ID=

# Optional network tuning
SCALA_CM_REQUEST_TIMEOUT_MS=30000
SCALA_CM_FORCE_IPV4=false

# TLS options for private/self-signed CA environments
# Recommended: provide CA PEM chain
SCALA_CM_CA_CERT_PEM=
# Temporary workaround only (disables cert verification)
SCALA_CM_TLS_INSECURE=false
